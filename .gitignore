# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local screenshots from QA captures (kept at repo root, not bundled with the site)
/portfolio-*.png
/portfolio-*.jpeg
/homepage-*.png
/nexus-case-study-*.png
/case-study-*.png
/pitch-nexus-*.png

# local scratch / scraping working dirs (not part of the portfolio)
/.playwright-mcp/
/.skool-scrape/
/.tbf-voice/
/.sabrina-voice/
/live-*.png
/live-*.jpeg

# vercel
.vercel

# --- security hardening: never publish local scratch / client-confidential / job-automation artifacts ---
# No .png/.jpeg/.yml/.txt/.html are legitimately tracked at repo root, so root-glob them as scratch.
# (package.json, package-lock.json, tsconfig.json stay tracked; only the specific scratch JSON below is ignored.)
/*.png
/*.jpeg
/*.jpg
/*.yml
/*.yaml
/*.txt
/*.html
/caps*.json
/endcard.json
/upwork-shortlist-*.md
# local scratch / automation / planning dirs and local Claude settings
/.li-jobs/
/.agents/
/.planning/
/.claude/
